\tab Sauvegarde la molecule au format PDB.\par
\par
\b Enregistrer .MOL... \b0\par
\tab Sauvegarde au format MDL Molfile V2000.\par
\par
\b Enregistrer session \b0\par
\tab Enregistre une session (vue, parametres, selection).\par
\par
\b Enregistrer image \b0\par
\tab Enregistre une capture du canevas au format BMP.\par
\par
\b Importer fragment... \b0\par
\tab Ajoute un fragment moleculaire a la scene courante.\par
\par
\b Exporter image PPM... \b0\par
\tab Exporte le canevas au format Portable Pixmap (PPM).\par
\par
\b Reinitialiser \b0 {\f1 Ctrl+R} \par
\tab Vide la molecule et remet les vues / parametres par defaut.\par
\par
\b Quitter \b0 {\f1 Alt+F4} \par
