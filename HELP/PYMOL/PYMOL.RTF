{\footnote # IDH_MENU_CONSTRUCTION}
{\footnote $ Menu Construction}
{\footnote K menu construction;build;fragment;residu;liaison}
\b\fs24 Menu Construction \b0\fs20\par
\par
Ajout rapide de fragments moleculaires prebatis :\par
\par
\b Fragment H2O \b0     - Molecule d'eau \par
\b Fragment CH4 \b0     - Methane \par
\b Fragment NH3 \b0     - Ammoniac \par
\b Fragment Benzene \b0 - Cycle benzenique C6H6 \par
\b Residu Glycine \b0   - Acide amine glycine \par
\b Residu Alanine \b0   - Acide amine alanine \par
\par
\b Detecter liaisons \b0\par
\tab Detecte automatiquement les liaisons d'apres les distances
inter-atomiques et les rayons covalents.\par
\par
\b Effacer hydrogenes \b0\par
\tab Supprime tous les atomes d'hydrogene de la molecule.\par
\page

